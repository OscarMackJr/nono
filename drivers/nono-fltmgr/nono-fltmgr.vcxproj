<?xml version="1.0" encoding="utf-8"?>
<!--
  nono-fltmgr WDK MSBuild project
  Source: structure mirrors github.com/microsoft/Windows-driver-samples
          filesys/miniFilter/nullFilter/nullFilter.vcxproj [CITED]

  ConfigurationType = Driver (required for .sys output)
  DriverType        = WDM   (minifilters are WDM-class FS filters, NOT KMDF)

  Build on the Azure WDK VM from an EWDK/Developer command prompt:
      msbuild nono-fltmgr.vcxproj /p:Configuration=Release /p:Platform=x64
  Expected output: x64\Release\nono-fltmgr.sys  (SC2 proof artifact; NOT committed)

  NOTE: The .sys binary is a throwaway VM-local compile artifact (Pitfall 6).
        Only the source scaffold is committed to the repo.
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <TargetName>nono-fltmgr</TargetName>
    <!-- ConfigurationType=Driver produces a .sys kernel binary -->
    <ConfigurationType>Driver</ConfigurationType>
    <!-- DriverType=WDM: minifilters are WDM-class file-system filters (not KMDF) -->
    <DriverType>WDM</DriverType>
    <!-- Required for kernel-mode C compilation -->
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
  </PropertyGroup>

  <!-- Import WDK property sheets (sets kernel-mode compile/link defaults) -->
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <Import Project="$(WDKContentRoot)\build\$(Platform)\WindowsDriver.props"
          Condition="'$(WDKContentRoot)' != ''" />

  <PropertyGroup Label="Configuration" Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <UseDebugLibraries>false</UseDebugLibraries>
    <WholeProgramOptimization>false</WholeProgramOptimization>
  </PropertyGroup>

  <PropertyGroup Label="Configuration" Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <UseDebugLibraries>true</UseDebugLibraries>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <ItemDefinitionGroup>
    <ClCompile>
      <!-- Spectre mitigation flags (nullFilter precedent; required for driver certification) -->
      <SpectreMitigation>Spectre</SpectreMitigation>
      <!-- Kernel-mode code must not use the CRT: -->
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <!-- Kernel entry points need C linkage -->
      <CompileAs>CompileAsC</CompileAs>
      <!-- fltKernel.h requires kernel include path — provided by WDK toolset -->
      <AdditionalIncludeDirectories>$(KernelIncludes);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <AdditionalOptions>/kernel %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
    <Link>
      <!-- Kernel drivers link against FltMgr.lib for FltRegisterFilter etc. -->
      <AdditionalDependencies>fltMgr.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <!-- Required for kernel-mode .sys -->
      <SubSystem>Native</SubSystem>
      <Driver>WDM</Driver>
    </Link>
    <Inf>
      <TimeStamp>$(DefaultInfTimeStamp)</TimeStamp>
    </Inf>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="nono-fltmgr.c" />
  </ItemGroup>

  <ItemGroup>
    <Inf Include="nono-fltmgr.inf" />
  </ItemGroup>

  <!-- Import WDK targets (sets .sys output extension, HAL linkage, etc.) -->
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <Import Project="$(WDKContentRoot)\build\$(Platform)\WindowsDriver.targets"
          Condition="'$(WDKContentRoot)' != ''" />
</Project>
